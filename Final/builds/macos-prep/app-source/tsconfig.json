{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main/**/*", "src/core/**/*"],
  "exclude": ["src/renderer/**/*", "node_modules"]
}
