{
  "name": "toolcad",
  "productName": "ToolCAD",
  "version": "1.0.0",
  "description": "Професійний CAD інструмент для технічного креслення",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "tsc && electron .",
    "dev": "tsc && electron . --dev",
    "build": "tsc && cpy \"src/renderer/**\" \"dist/renderer/\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:mac": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder --mac --universal"
  },
  "build": {
    "appId": "com.toolcad.app",
    "productName": "ToolCAD",
    "copyright": "Copyright © 2024 ToolCAD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "icon/",
        "to": "icon/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "icon/icon.ico",
      "uninstallerIcon": "icon/icon.ico",
      "installerHeaderIcon": "icon/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ToolCAD",
      "installerLanguages": [
        "uk_UA",
        "en_US"
      ],
      "language": "1058",
      "license": "LICENSE.txt",
      "installerSidebar": "icon/installer-sidebar.bmp",
      "uninstallerSidebar": "icon/installer-sidebar.bmp"
    },
    "portable": {
      "artifactName": "ToolCAD-Portable-${version}.exe"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon/icon.icns",
      "category": "public.app-category.graphics-design",
      "minimumSystemVersion": "11.0"
    },
    "dmg": {
      "sign": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "cpy-cli": "^5.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "simplify-js": "^1.2.4",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "jspdf": "^2.5.1"
  }
}
